# Telegram bot token, выданный @BotFather
BOT_TOKEN=

# Telegram ID единственного владельца бота
ADMIN_TELEGRAM_ID=

# Часовой пояс для напоминаний и отображения дат
TIMEZONE=Europe/Istanbul

# Дни напоминаний через запятую (за сколько дней до списания слать уведомление)
REMINDER_DAYS=1,3,7

# Путь к SQLite базе (относительно корня проекта)
DATABASE_URL=sqlite:///data/subscriptions.db

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO